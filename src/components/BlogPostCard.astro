---
import { calculateReadingTime } from "../utils/readingTime";

interface Props {
  post: any;
}

const { post } = Astro.props;
const readingTime = calculateReadingTime(post.body);
---

<a
  href={`${import.meta.env.BASE_URL}blog/${post.slug}/`}
  class="group flex flex-col gap-5 blog-card-hover bg-white p-5 rounded-[2rem] border border-gray-100 prominent-card"
>
  {
    post.data.image && (
      <div class="aspect-[16/11] overflow-hidden rounded-2xl">
        <img
          src={post.data.image}
          alt={post.data.title}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </div>
    )
  }
  <div class="flex flex-col gap-4 px-2 pb-2">
    <div
      class="flex items-center gap-2 text-xs font-bold text-primary uppercase tracking-wider"
    >
      {
        post.data.tags && post.data.tags.length > 0 && (
          <>
            <span>{post.data.tags[0]}</span>
            <span class="text-gray-300">•</span>
          </>
        )
      }
      <span class="text-gray-500">{readingTime} min read</span>
    </div>
    <h3
      class="text-2xl font-black leading-tight group-hover:text-primary transition-colors"
    >
      {post.data.title}
    </h3>
    <p class="text-gray-600 text-sm line-clamp-2">
      {post.data.description}
    </p>
    <div class="flex items-center gap-3 pt-2">
      <div
        class="size-8 rounded-full bg-gray-200 overflow-hidden ring-2 ring-primary/10"
      >
        <img
          alt="Author"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuA501VXtx1RUsOioxpyuH8Q_8fFWhu_TIwOZcg6TSAL50Q3XqaJ4L_eVwKuDeB7Dwg9e7r4kNkOft61ixdFUuYCorBRp2ouO7rMjdtSlXwIkbO3E-kARjHqJ2RwzGqvlwPg7s6k_T4blmQ_UKm7C_spgp0R7A33hxdcAYrujyDas23m-tUXtNjntR-8vOSFPDPhNhT4HUPtdO2jnU0mS4YaKjYqu9N5FMqhen6XO3mvwTuQkrflVWNfJTA65BEWJZiD31h-5xdQ6dkm"
        />
      </div>
      <div class="flex flex-col">
        <span class="text-xs font-bold">
          {post.data.author}
        </span>
        <span class="text-[10px] text-gray-500 font-medium">
          {post.data.pubDate.toLocaleDateString()}
        </span>
      </div>
    </div>
  </div>
</a>
