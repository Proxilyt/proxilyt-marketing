---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Proxilyt | Local SEO Analytics & Competitive Intelligence"
  description="Transform local search data into actionable growth strategies. Track competitor rankings, analyze local keywords, and dominate your market."
>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <div class="relative min-h-screen w-full flex flex-col dot-pattern">
    <!-- Header / Navigation -->
    <header
      class="flex items-center justify-between whitespace-nowrap border-b border-solid border-gray-200 px-10 py-5 bg-white/80 backdrop-blur-md sticky top-0 z-50"
      role="banner"
    >
      <div class="flex items-center gap-4 text-primary">
        <img 
          src={`${import.meta.env.BASE_URL}favicon.svg`} 
          alt="Proxilyt logo" 
          class="size-10" 
        />
        <h1
          class="text-2xl font-semibold leading-tight tracking-[-0.015em] mt-[12px] ml-[-6px]"
          style="font-family: 'League Spartan', sans-serif;"
        >
          Proxilyt
        </h1>
      </div>
      <nav class="flex flex-1 justify-end gap-8">
        <div class="hidden sm:flex items-center gap-9">
          <a
            class="text-sm font-medium hover:text-primary transition-colors"
            href="#features">Features</a
          >
        </div>
        <div class="flex gap-4">
          <a
            href="https://app.proxilyt.com"
            class="flex min-w-[84px] cursor-pointer items-center justify-center rounded-lg h-10 px-4 bg-primary text-white text-sm font-bold shadow-lg shadow-primary/20 hover:scale-105 transition-transform"
          >
            <span>Get Started</span>
          </a>
        </div>
      </nav>
    </header>
    <!-- Main Content -->
    <main id="main-content" class="flex-grow flex flex-col items-center">
      <div class="relative w-full overflow-hidden flex flex-col items-center">
        <div
          class="absolute inset-0 pointer-events-none z-0 lg:hidden floating-grid opacity-[0.4]"
          aria-hidden="true"
        >
          <div
            class="absolute inset-0 grid grid-cols-6 grid-rows-8 gap-4 p-4 opacity-40"
          >
            <div
              class="rounded-lg bg-primary h-16 w-16 md:h-24 md:w-24 mt-20 ml-10"
            >
            </div>
            <div
              class="rounded-lg bg-gray-200/20 h-20 w-20 md:h-32 md:w-32 col-start-4 row-start-2"
            >
            </div>
            <div
              class="rounded-lg bg-accent h-12 w-12 md:h-20 md:w-20 col-start-2 row-start-4"
            >
            </div>
            <div
              class="rounded-lg bg-primary/30 h-24 w-24 md:h-40 md:w-40 col-start-5 row-start-3"
            >
            </div>
            <div
              class="rounded-lg bg-accent/20 h-32 w-32 md:h-48 md:w-48 col-start-1 row-start-6"
            >
            </div>
            <div
              class="rounded-lg bg-primary/10 h-20 w-20 md:h-32 md:w-32 col-start-3 row-start-5"
            >
            </div>
            <div class="rounded-lg bg-accent h-14 w-14 col-start-5 row-start-6">
            </div>
            <div
              class="rounded-lg bg-primary h-10 w-10 col-start-6 row-start-1"
            >
            </div>
          </div>
        </div>
        <!-- Hero Section -->
        <section class="max-w-[1280px] w-full px-6 py-8 relative z-10">
          <div
            class="flex flex-col lg:grid lg:grid-cols-2 gap-12 lg:gap-16 items-center"
          >
            <article class="flex flex-col gap-8 order-1 items-center text-center lg:items-start lg:text-left">
              <div class="flex flex-col gap-4">
                <span
                  class="text-primary font-bold tracking-widest text-xs uppercase"
                  >Local SEO Intelligence</span
                >
                <h2
                  class="text-4xl md:text-6xl lg:text-6xl font-black leading-[1.1] tracking-[-0.03em]"
                >
                  Local competitive analytics made
                  <span class="text-primary">Actionable.</span>
                </h2>
                <p
                  class="text-lg md:text-xl text-gray-600 max-w-[540px] leading-relaxed mx-auto lg:mx-0"
                >
                  Transform your nearby search data into actionable growth 
                  strategies before your competitors even see the opportunity.
                </p>
              </div>
              <div class="flex flex-wrap justify-center lg:justify-start gap-4">
                <a
                  href="https://app.proxilyt.com"
                  class="flex min-w-[160px] cursor-pointer items-center justify-center rounded-xl h-14 px-8 bg-primary text-white text-base font-bold shadow-xl shadow-primary/30 hover:shadow-primary/40 transition-all"
                >
                  <span>Start Growing Locally</span>
                </a>
                <button
                  class="flex min-w-[160px] cursor-pointer items-center justify-center rounded-xl h-14 px-8 border-2 border-gray-200 text-base font-bold hover:bg-white transition-all"
                >
                  <span>Watch Demo</span>
                </button>
              </div>
              <div
                class="flex items-center gap-4 pt-4 border-t border-gray-100 w-full justify-center lg:justify-start"
              >
                <div class="flex -space-x-3">
                  <img 
                    src={`${import.meta.env.BASE_URL}iec_logo.png`} 
                    alt="IEC partner logo - trusted by local agencies" 
                    class="h-10 w-10 rounded-full border-2 border-white object-cover"
                  />
                  <img 
                    src={`${import.meta.env.BASE_URL}homebuild_logo.jpg`} 
                    alt="HomeBuild partner logo - trusted by local agencies" 
                    class="h-10 w-10 rounded-full border-2 border-white object-cover"
                  />
                  <img 
                    src={`${import.meta.env.BASE_URL}ktc_logo.jpg`} 
                    alt="KTC partner logo - trusted by local agencies" 
                    class="h-10 w-10 rounded-full border-2 border-white object-cover"
                  />
                </div>
                <p class="text-sm text-gray-500">
                  Trusted by local agencies
                </p>
              </div>
            </article>
            <div
              class="hidden lg:grid order-2 relative aspect-square max-w-[500px] mx-auto w-full grid-cols-5 gap-3"
              aria-hidden="true"
            >
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-primary/20 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-primary shadow-lg shadow-primary/40 transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-accent/40 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-primary/40 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-accent shadow-lg shadow-accent/40 transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-primary/60 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-accent/20 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-primary shadow-lg shadow-primary/40 transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-primary/30 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
              <div
                class="rounded-lg bg-gray-100 shadow-sm transition-all hover:scale-110"
              >
              </div>
            </div>
          </div>
        </section>
      </div>
      <!-- Features Section -->
      <section
        id="features"
        class="max-w-[1280px] w-full px-6 py-8 flex flex-col gap-16"
      >
        <div class="flex flex-col md:flex-row justify-around items-center gap-6 text-center">
          <div class="flex flex-col gap-4 max-w-[600px]">
            <h2
              class="text-3xl md:text-5xl font-black leading-tight tracking-tight"
            >
              Engineered for Local Dominance
            </h2>
            <p class="text-lg text-gray-600">
              Advanced tools designed to give you a competitive edge in local
              search rankings across any geographical grid.
            </p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <article
            class="flex flex-col gap-3 rounded-xl border border-[#dddde4] bg-white p-6 hover:border-primary/50 transition-colors"
          >
            <div class="text-primary" aria-hidden="true">
              <span class="material-symbols-outlined text-3xl">grid_on</span>
            </div>
            <div class="flex flex-col gap-1">
              <h3
                class="text-[#121217] text-lg font-bold leading-tight"
              >
                Local Geographic Insights
              </h3>
              <p
                class="text-[#6a6783] text-base font-normal leading-normal"
              >
                Track all the ranks for all the keywords across multiple 
                locations.
              </p>
            </div>
          </article>
          <article
            class="flex flex-col gap-3 rounded-xl border border-[#dddde4] bg-white p-6 hover:border-primary/50 transition-colors"
          >
            <div class="text-primary" aria-hidden="true">
              <span class="material-symbols-outlined text-3xl">groups</span>
            </div>
            <div class="flex flex-col gap-1">
              <h3
                class="text-[#121217] text-lg font-bold leading-tight"
              >
                Competitor Analysis
              </h3>
              <p
                class="text-[#6a6783] text-base font-normal leading-normal"
              >
                Get comprehensive competitive insights for all the queries and 
                see the lapses in your local SEO strategies.
              </p>
            </div>
          </article>
          <article
            class="flex flex-col gap-3 rounded-xl border border-[#dddde4] bg-white p-6 hover:border-primary/50 transition-colors"
          >
            <div class="text-primary" aria-hidden="true">
              <span class="material-symbols-outlined text-3xl">monetization_on</span>
            </div>
            <div class="flex flex-col gap-1">
              <h3
                class="text-[#121217] text-lg font-bold leading-tight"
              >
                Keyword Economics
              </h3>
              <p
                class="text-[#6a6783] text-base font-normal leading-normal"
              >
                Understand the cost of appearing in local searches and the 
                amount of attention each search term gets.
              </p>
            </div>
          </article>
          <article
            class="flex flex-col gap-3 rounded-xl border border-[#dddde4] bg-white p-6 hover:border-primary/50 transition-colors"
          >
            <div class="text-primary" aria-hidden="true">
              <span class="material-symbols-outlined text-3xl"
                >track_changes</span
              >
            </div>
            <div class="flex flex-col gap-1">
              <h3
                class="text-[#121217] text-lg font-bold leading-tight"
              >
                Local Ads Management
              </h3>
              <p
                class="text-[#6a6783] text-base font-normal leading-normal"
              >
                Use local Google Ads to cover ranking gaps while your organic 
                visibility scales.
              </p>
            </div>
          </article>
        </div>
      </section>
      <!-- CTA Section -->
      <section class="max-w-[1120px] w-full px-6 py-8">
        <div
          class="relative bg-primary rounded-[2.5rem] overflow-hidden p-8 md:p-20 text-center text-white flex flex-col items-center gap-8"
        >
          <!-- Background shapes -->
          <div
            class="absolute top-0 left-0 w-full h-full opacity-10 dot-pattern pointer-events-none"
            aria-hidden="true"
          >
          </div>
          <div
            class="absolute -top-24 -right-24 w-96 h-96 bg-accent rounded-full blur-[100px] opacity-20"
            aria-hidden="true"
          >
          </div>
          <h2
            class="text-3xl md:text-5xl font-black max-w-[800px] relative z-10"
          >
            If local search drives revenue, Proxilyt drives results.
          </h2>
          <p
            class="text-lg md:text-xl text-white/80 max-w-[640px] relative z-10"
          >
            Turn local intent into measurable growth. Proxilyt shows you what 
            customers are searching, why competitors are winning, and exactly what to fix to capture more inbound calls and foot traffic.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 relative z-10">
            <a
              href="https://app.proxilyt.com"
              class="flex min-w-[200px] cursor-pointer items-center justify-center rounded-xl h-14 px-8 bg-white text-primary text-base font-bold shadow-xl hover:scale-105 transition-all"
            >
              <span>Get Local Advantage</span>
            </a>
            <button
              class="flex min-w-[200px] cursor-pointer items-center justify-center rounded-xl h-14 px-8 border-2 border-white/30 text-white text-base font-bold hover:bg-white/10 transition-all"
            >
              <span>Watch Demo</span>
            </button>
          </div>
          <!-- <p class="text-sm text-white/60 relative z-10">
            No credit card required • 14-day free trial
          </p> -->
        </div>
      </section>
    </main>
    <!-- Footer -->
    <footer
      class="border-t border-gray-200 bg-white/50 backdrop-blur-sm px-10 py-8"
      role="contentinfo"
    >
      <div
        class="max-w-[1280px] w-full mx-auto flex flex-col md:flex-row justify-between items-center gap-8 md:gap-12"
      >
        <div class="flex items-center gap-3 text-primary">
          <img 
            src={`${import.meta.env.BASE_URL}favicon.svg`} 
            alt="Proxilyt" 
            class="size-6" 
          />
          <h3
            class="text-lg font-bold leading-tight tracking-[-0.015em] mt-[7px]"
            style="font-family: 'League Spartan', sans-serif;"
          >
            Proxilyt
          </h3>
        </div>
        <p class="text-gray-500 text-sm hidden lg:block flex-1">
          The leading platform for local search performance and competitive intelligence.
        </p>
        <div class="flex items-center gap-8">
          <nav class="flex gap-6">
            <a
              class="text-gray-500 hover:text-primary transition-colors text-sm font-medium"
              href={`${import.meta.env.BASE_URL}legal/privacy-policy.pdf`} 
              target="_blank"
              rel="noopener noreferrer">Privacy Policy</a
            >
            <a
              class="text-gray-500 hover:text-primary transition-colors text-sm font-medium"
              href={`${import.meta.env.BASE_URL}legal/terms-of-use.pdf`} 
              target="_blank"
              rel="noopener noreferrer">Terms of Service</a
            >
          </nav>
          <nav class="flex gap-4" aria-label="Social links">
            <a
              class="text-gray-400 hover:text-primary transition-colors"
              href="https://www.instagram.com/proxilyt.local/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
            >
              <i class="fab fa-instagram text-lg"></i>
            </a>
            <a
              class="text-gray-400 hover:text-primary transition-colors"
              href="https://www.linkedin.com/company/proxilyt/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
            >
              <i class="fab fa-linkedin text-lg"></i>
            </a>
            <a
              class="text-gray-400 hover:text-primary transition-colors"
              href="mailto:main.proxilyt@gmail.com"
              aria-label="Email"
            >
              <i class="fas fa-envelope text-lg"></i>
            </a>
          </nav>
        </div>
      </div>
      <p class="text-gray-400 text-xs text-center md:text-left mt-6 md:absolute md:bottom-2 md:left-10">
        &copy; 2026 Proxilyt Inc. All rights reserved.
      </p>
    </footer>
  </div>
</BaseLayout>
