---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);
---

<BaseLayout
  title="Blog | Proxilyt"
  description="Latest updates and insights from Proxilyt"
>
  <div class="flex flex-col min-h-screen bg-gradient-to-br from-slate-50 to-slate-100">
    <Header isHome={false} />
    <main class="flex-1 max-w-4xl mx-auto w-full px-6 py-16 sm:px-8 sm:py-20">
      <h1 class="text-4xl font-bold mb-8">Blog</h1>
      <div class="grid gap-6 md:grid-cols-2">
        {
          posts.map((post) => (
            <article class="border rounded-lg overflow-hidden hover:shadow-lg transition-shadow flex flex-col">
              {post.data.image && (
                <img src={post.data.image} alt={post.data.title} class="w-full h-48 object-cover" />
              )}
              <div class="p-6 flex flex-col flex-1">
              <h2 class="text-2xl font-bold mb-2">
                <a
                  href={`/proxilyt-marketing/blog/${post.slug}/`}
                  class="hover:text-blue-600"
                >
                  {post.data.title}
                </a>
              </h2>
              <p class="text-gray-600 text-sm mb-3">
                {post.data.pubDate.toLocaleDateString()}
                {post.data.author && ` • By ${post.data.author}`}
              </p>
              <p class="text-gray-700 mb-4">{post.data.description}</p>
              {post.data.tags && (
                <div class="flex flex-wrap gap-2 mb-4">
                  {post.data.tags.map((tag) => (
                    <span class="bg-gray-200 text-gray-800 text-xs px-2 py-1 rounded">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
              <a
                href={`/proxilyt-marketing/blog/${post.slug}/`}
                class="text-blue-600 hover:underline"
              >
                Read More →
              </a>
              </div>
            </article>
          ))
        }
      </div>
    </main>
    <!-- Footer -->
    <Footer />
  </div>
</BaseLayout>
